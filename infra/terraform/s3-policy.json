{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::credit-card-fraud-mlops-bucket",
                "arn:aws:s3:::credit-card-fraud-mlops-bucket/*",
                "arn:aws:s3:::fraud-mlops-mlflow-artifacts",
                "arn:aws:s3:::fraud-mlops-mlflow-artifacts/*"
            ]
        }
    ]
}
